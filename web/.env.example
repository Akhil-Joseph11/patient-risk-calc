# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Turso (required) — https://docs.turso.tech/quickstart
# Prisma + runtime need a libsql:// URL. You can set only TURSO_DATABASE_URL=libsql://…
# and keep DATABASE_URL=libsql://… the same, or set both.
DATABASE_URL=libsql://YOUR-DATABASE.turso.io
TURSO_DATABASE_URL=
# Also accepts LIBSQL_AUTH_TOKEN in some setups
TURSO_AUTH_TOKEN=

# ═══ Clinical note analysis (server-side only — set on Next.js / Vercel, never NEXT_PUBLIC_) ═══
# Cascade: Groq → Gemini → OpenAI → deterministic rules. Omit all keys to use rules only.

# Groq (OpenAI-compatible)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_API_BASE=https://api.groq.com/openai/v1

# Google Gemini (either key works)
GEMINI_API_KEY=
# GOOGLE_API_KEY=

GEMINI_MODEL=gemini-flash-latest

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: prisma seed (`npm run db:seed`) — needs Clerk user id
# SEED_CLERK_USER_ID=user_xxxxx

# ═══ Vercel (Production / Preview) ═══
# In Vercel → Project → Settings → Environment Variables, add the same keys as above.
# Required for the live app: Clerk keys, DATABASE_URL (libsql://…), TURSO_AUTH_TOKEN.
# Optional: GROQ_API_KEY (recommended), GEMINI_API_KEY / OPENAI_API_KEY for fallbacks.
# Import GitHub repo with Root Directory set to `web`. See README → Deploy on Vercel.
